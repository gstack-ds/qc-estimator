{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": [
    "src/**/*",
    "../src/lib/deck/**/*",
    "../src/lib/contracts/**/*",
    "../src/lib/engine/**/*",
    "../src/types/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
