# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gmail Scanner (Phase 2)
# Create OAuth2 credentials at console.cloud.google.com → APIs & Services → Credentials
# Application type: "Desktop app", then run: npm run auth
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token-from-npm-run-auth

# Scanner notifications — email address that receives scan summaries and error alerts
NOTIFY_EMAIL=your-email@example.com

# Google Maps (Slide Copy Module — drive time calculator)
# Enable Distance Matrix API at console.cloud.google.com → APIs & Services
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Deck Renderer (PM2 service — runs alongside the Gmail scanner on your local box)
# RENDERER_SECRET: random string; must match the same var in Vercel env vars
# RENDERER_URL in Vercel: http://<tailscale-ip>:3001 — set to 127.0.0.1 for local dev
RENDERER_SECRET=your-random-secret
RENDERER_URL=http://127.0.0.1:3001
